{
  "name": "ai-compliance-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test --pass-with-no-tests",
    "electron:dev": "electron electron/main.js",
    "electron:build": "next build && electron-builder build"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.56.0",
    "next": "14.2.14",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.47.2",
    "typescript": "5.6.2",
    "tailwindcss": "3.4.13",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourcompany.aicomplianceplatform",
    "productName": "AI Compliance Platform",
    "win": {
      "target": "nsis"
    },
    "files": [
      "out/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
